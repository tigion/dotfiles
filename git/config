# vim: set filetype=gitconfig:

[color]
  ui = auto
  diff = auto
  status = auto
  branch = auto
[core]
  excludesfile = "~/.config/git/ignore"
  editor = nvim
  filemode = false
  pager = delta
[diff]
  colorMoved = default # color moved lines in diffs (git diff --color-moved)
[init]
  defaultBranch = main # set default branch name for new repositories
[interactive]
  diffFilter = delta --color-only --features=interactive
[merge]
  conflictstyle = zdiff3 # use a 3-way diff style for merge conflicts (git merge --conflict=zdiff3)
  ff = false # disable fast-forward merges to preserve history (git merge --no-ff ...)
[mergetool]
  keepBackup = true # keep backup files after a merge conflict is resolved (git mergetool --keepBackup)
[pack]
  threads = 0 # use all available CPU cores for packing objects (git gc --threads=0)
[pull]
  rebase = true # rebase by default when pulling (git pull --rebase)
[rebase]
  autoStash = true # automatically stash and pop local changes when rebasing (git rebase --autostash)

[delta]
  line-numbers = true
  keep-plus-minus-markers = true
  hunk-header-decoration-style = omit
  zero-style = dim syntax
[delta "interactive"]
  keep-plus-minus-markers = false

[include]
  path = "~/.config/git/config.private"
